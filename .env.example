PAYOS_ENABLED=true
PAYOS_BASE_URL=https://api-merchant.payos.vn
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key
PAYOS_RETURN_URL=http://localhost:3001/payment/success
PAYOS_CANCEL_URL=http://localhost:3001/payment/cancel

# Gmail SMTP (use a Google App Password, not the normal account password)
SMTP_USERNAME=your-email@gmail.com
SMTP_APP_PASSWORD=your-16-character-app-password
JWT_SIGNER_KEY=generate-a-strong-64-character-secret
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
CONFIG_MINIO_ACCESS_KEY=minioadmin
CONFIG_MINIO_SECRET_KEY=minioadmin
INTERNAL_SERVICE_KEY=replace-with-a-long-random-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax
AUTH_COOKIE_DOMAIN=

# Gemini course-consulting chatbot
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite
CHATBOT_RATE_LIMIT_PER_MINUTE=20
CHAT_ALLOWED_ORIGINS=http://localhost:3001
